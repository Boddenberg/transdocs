APP_NAME="TransDocs API"
APP_ENV="local"
API_PREFIX="/api/v1"
CORS_ORIGINS="http://localhost:3000"

# Supabase exclusivo do TransDocs
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DOCUMENTS_BUCKET="documentos"

# OpenAI (somente backend)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_TIMEOUT_SECONDS="90"

# Limites e processamento
MAX_UPLOAD_BYTES="26214400"
MAX_EXTRACTED_TEXT_CHARS="120000"
SIGNED_URL_TTL_SECONDS="300"


APP_NAME="ThiagoDocs API"
APP_ENV="local"
API_PREFIX="/api/v1"
CORS_ORIGINS="http://localhost:3000"

# Supabase exclusivo do TransDocs
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DOCUMENTS_BUCKET="documentos"
SUPABASE_SUGGESTIONS_BUCKET="sugestoes"
SUPABASE_FILLINGS_BUCKET="preenchimentos"

# Chave aleatória longa para consultar todas as sugestões via API administrativa.
SUGGESTIONS_ADMIN_KEY=""

# OpenAI (somente backend)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_TIMEOUT_SECONDS="90"
OPENAI_INPUT_USD_PER_MILLION="0.75"
OPENAI_OUTPUT_USD_PER_MILLION="4.50"
USD_BRL_RATE="5.50"

# Limites e processamento
MAX_UPLOAD_BYTES="52428800"
MAX_FULL_ANALYSIS_BYTES="26214400"
MAX_EXTRACTED_TEXT_CHARS="120000"
MAX_FILLING_SOURCES_BYTES="104857600"
SIGNED_URL_TTL_SECONDS="300"
MAX_SUGGESTION_ATTACHMENT_BYTES="10485760"
